# --- Build dynamic INSERT (keep format same, no explicit column list hardcoded) ---

# Make sure BigQuery fqdn is project.dataset.table (not project:dataset.table)
src_sql_tbl = src_tbl.replace(":", ".")
tgt_sql_tbl = tgt_tbl.replace(":", ".")

# Target schema order (this is the order we must follow)
tgt_fields = [f.name for f in bq_client.get_table(tgt_sql_tbl).schema]

# Source columns (to decide whether to use S.col or NULL)
src_fields = set([f.name for f in bq_client.get_table(src_sql_tbl).schema])

# Build SELECT expressions in target order
select_exprs = []
for c in tgt_fields:
    if c == valid_from_col:
        select_exprs.append(f"CAST(CURRENT_TIMESTAMP() AS STRING) AS {valid_from_col}")
    elif c == valid_to_col:
        select_exprs.append(f"CAST(TIMESTAMP('{open_end_date}') AS STRING) AS {valid_to_col}")
    elif c == is_current_col:
        select_exprs.append(f"'Y' AS {is_current_col}")
    elif c == dml_flag_col:
        select_exprs.append(f"CASE WHEN T.{merge_keys[0]} IS NULL THEN 'I' ELSE 'U' END AS {dml_flag_col}")
    elif c == row_hash_col:
        # row_hash fetched from source
        if row_hash_col in src_fields:
            select_exprs.append(f"S.{row_hash_col} AS {row_hash_col}")
        else:
            select_exprs.append(f"NULL AS {row_hash_col}")
    else:
        # normal cols
        if c in src_fields:
            select_exprs.append(f"S.{c} AS {c}")
        else:
            select_exprs.append(f"NULL AS {c}")

insert_cols = ", ".join([f"`{c}`" for c in tgt_fields])
select_list = ",\n    ".join(select_exprs)

insert_sql = f"""
INSERT INTO `{tgt_sql_tbl}` ({insert_cols})
SELECT
    {select_list}
FROM {src_using_sql} S
LEFT JOIN `{tgt_sql_tbl}` T
ON {on_clause}
WHERE
    T.{merge_keys[0]} IS NULL
    OR ({changed_cond})
"""

print(insert_sql)
bq_client.query(insert_sql).result()
